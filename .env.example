# Copy to .env and adjust. The .env file is gitignored.

# SQL Server SA password used by the sqlserver compose service.
SA_PASSWORD=Your_Password123

# Connection string the API container uses to reach SQL Server.
# Use the service name 'sqlserver' — docker-compose DNS resolves it.
CONNECTION_STRING=Server=sqlserver,1433;Database=TaskManagement;User Id=sa;Password=Your_Password123;TrustServerCertificate=True;MultipleActiveResultSets=True;

# JWT signing secret. MUST be at least 32 chars (256-bit key for HS256).
# Generate a fresh value in production, never reuse this one.
JWT_SECRET_KEY=replace-me-with-a-strong-random-256-bit-secret-1234
JWT_ISSUER=TaskManagement.Api
JWT_AUDIENCE=TaskManagement.Client

# Comma-separated origins allowed to call the API from a browser.
# Add your React dev server URL here.
CORS_ORIGINS=http://localhost:5173,https://localhost:5173

# Frontend runtime config — consumed by docker-entrypoint.sh to produce
# /env.js at container start. The bundle reads window.__RUNTIME_CONFIG__
# before any app code runs, so one image serves every environment.
FRONTEND_API_BASE_URL=http://localhost:8080
