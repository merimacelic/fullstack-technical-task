# Copy to deploy.env and fill in. deploy.env is git-ignored.

# Azure subscription id or friendly name.
AZURE_SUBSCRIPTION=00000000-0000-0000-0000-000000000000

# Region. Azure SQL Free Offer is region-restricted; West Europe works.
AZURE_LOCATION=westeurope

# Resource group — created if it doesn't exist.
RESOURCE_GROUP=rg-taskmanagement

# 3-12 chars, lowercase, alphanumeric. Used as a prefix for every resource.
PROJECT_NAME=tasksmt

# SQL Server admin. Must NOT be one of the reserved names (admin, sa, root,
# dbmanager, loginmanager, dbo, guest, public).
SQL_ADMIN_LOGIN=tasksmtadmin
SQL_ADMIN_PASSWORD=Ch4ngeMePlease!2026

# 32+ character JWT signing secret. Rotate per environment.
JWT_SECRET=replace-with-a-32-plus-character-random-string-please

# Images published by CI to GHCR. The default ci.yml in this repo pushes to
# ghcr.io/<owner>/<repo>/{api,frontend}. Leave :latest for the head of main,
# or pin to a commit SHA for reproducibility.
API_IMAGE=ghcr.io/OWNER/task-management/api:latest
SPA_IMAGE=ghcr.io/OWNER/task-management/frontend:latest

# Whether the API should run the demo-data seeder on first boot.
SEED_DEMO_DATA=true

# Optional: an extra CORS origin (e.g. a custom domain fronting the SPA).
# Leave empty to only allow the Container App's default *.azurecontainerapps.io hostname.
EXTRA_CORS_ORIGIN=
